{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "env": {
    "NEXT_PUBLIC_BACKEND_URL": "https://betting-backend-adlh.onrender.com",
    "NEXT_PUBLIC_API_URL": "https://betting-backend-adlh.onrender.com/api"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://betting-backend-adlh.onrender.com/api/:path*"
    }
  ]
}
